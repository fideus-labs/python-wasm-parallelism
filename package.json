{
  "name": "pyodide-worker-pool-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Parallel CPU-bound Python in WebAssembly: a pool of Pyodide-running Web Workers driven by @fideus-labs/worker-pool",
  "license": "MIT",
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:web": "vite build",
    "build:lite": "cd demos/jupyterlite && ../../.venv/bin/jupyter lite build",
    "serve:lite": "node scripts/serve-lite.mjs",
    "dev": "vite",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc --noEmit -p web",
    "demo:node": "npm run build && tsx examples/node-demo.ts",
    "demo:dask": "npm run build && tsx examples/node-dask-demo.ts",
    "bench": "tsx bench/run-bench.ts",
    "bench:report": "tsx bench/run-bench.ts --report-only",
    "bench:report:browser": "tsx bench/report-browser-cli.ts",
    "test": "vitest run",
    "test:browser": "playwright test --grep-invert @bench"
  },
  "dependencies": {
    "@fideus-labs/worker-pool": "^1.0.0",
    "pyodide": "^314.0.2",
    "web-worker": "^1.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
